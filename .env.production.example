# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generá valores únicos con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZAR_CON_VALOR_UNICO

# Generá con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REEMPLAZAR_CON_VALOR_UNICO

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Base de datos ─────────────────────────────────────────────────────────────
# Con Docker usa la ruta del volumen montado en /data
DATABASE_URL=sqlite:////data/contable.db

# ── Almacenamiento de archivos xlsx ───────────────────────────────────────────
STORAGE_PATH=/data/storage

# ── CORS (solo si el frontend está en otro dominio/puerto) ────────────────────
# Dejar vacío si frontend y backend corren en el mismo servidor
# CORS_ORIGINS=https://tudominio.com
